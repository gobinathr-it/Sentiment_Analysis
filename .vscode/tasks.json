{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run AI Virtual Mouse",
      "type": "shell",
      "command": "python",
      "args": [
        "main.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}
